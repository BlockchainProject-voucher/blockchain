# Sepolia testnet deployment placeholders.
# Copy this file to .env locally and fill values on your own machine only.
# Never commit .env, private keys, or RPC API keys.

SEPOLIA_RPC_URL=<Sepolia RPC URL>
SEPOLIA_DEPLOYER_PRIVATE_KEY=<0x-prefixed deployer test wallet private key>
SEPOLIA_NETWORK_ID=11155111
SEPOLIA_CONFIRMATIONS=2
SEPOLIA_TIMEOUT_BLOCKS=200
SEPOLIA_POLLING_INTERVAL_MS=8000
